NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only, never exposed to the browser. Used for privileged admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your production URL (used for SEO metadata, sitemap.xml, robots.txt). Defaults to
# http://localhost:3000 if unset — set this to your real domain in Vercel.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional — analytics. Leave unset to disable (see SETUP.md for where to get these).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Optional — order confirmation emails via Resend (see SETUP.md).
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@yourdomain.com
